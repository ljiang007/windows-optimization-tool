{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "系统工具箱",
  "version": "1.0.0",
  "identifier": "com.local.system-toolbox.tauri",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "系统工具箱",
        "width": 540,
        "height": 720,
        "minWidth": 540,
        "minHeight": 360,
        "maxWidth": 540,
        "resizable": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
